    <function name="Sorter" type="None" variable="">
        <parameters>
            <parameter name="Arr" type="Real" array="False"/>
            <parameter name="ArraySize" type="Integer" array="False"/>
            <parameter name="Index" type="Integer" array="False"/>
        </parameters>
        <body>
            <declare name="val, Max, Maxidx, temp, index, i, j, ii" type="Integer" array="False" size=""/>
            <for variable="ii" start="o" end="ArraySize" direction="inc" step="1">
                <output expression="&quot;Assign Value to Index&quot;" newline="True"/>
                <assign variable="Arr[ii]" expression="ii"/>
            </for>
            <for variable="i" start="0" end="ArraySize-1" direction="inc" step="1">
                <output expression="&quot;Assign value to Max and Maxidx&quot;" newline="True"/>
                <assign variable="Max" expression="Arr[i]"/>
                <assign variable="Maxidx" expression="temp"/>
                <for variable="j" start="i" end="ArraySize" direction="inc" step="1">
                    <if expression="Arr[j]&gt;Max">
                        <then>
                            <output expression="&quot;New value for Maximum&quot;" newline="True"/>
                            <assign variable="Max" expression="Arr[i]"/>
                            <assign variable="Maxidx" expression="j"/>
                        </then>
                        <else/>
                    </if>
                </for>
                <if expression="Max&gt;Arr[i]">
                    <then>
                        <output expression="&quot;Assigning of values in array in variables: temp/ Arr[i]/ Arr[Maxidx]/ indexes[i]&quot;" newline="True"/>
                        <output expression="&quot;Assigning of value referring to index.Variables: Index/ indexes[Maxidx]/ indexes[j]&quot;" newline="True"/>
                    </then>
                    <else/>
                </if>
            </for>
        </body>
    </function>
    <function name="toFile" type="None" variable="">
        <parameters>
            <parameter name="Arrvalue" type="String" array="False"/>
            <parameter name="Arrindex" type="Integer" array="False"/>
            <parameter name="number" type="Integer" array="False"/>
            <parameter name="Player" type="Integer" array="False"/>
        </parameters>
        <body>
            <open expression="Finale" mode="write"/>
            <for variable="i" start="0" end="number-1" direction="inc" step="1">
                <output expression="&quot;Save player rankings of overall score to file Finale&quot;" newline="True"/>
                <write expression="&quot;Write Score,Rank,and name to file&quot;"/>
            </for>
            <close/>
            <open expression="Finale" mode="read"/>
            <for variable="i" start="0" end="number-1" direction="inc" step="1">
                <read variable="Arrvalue"/>
                <read variable="arrindex"/>
                <read variable="number"/>
                <read variable="players"/>
                <output expression="&quot;Display the contents of file Finale&quot;" newline="True"/>
            </for>
            <close/>
        </body>
    </function>
    <function name="toFilePer" type="None" variable="">
        <parameters>
            <parameter name="Arrvalue" type="String" array="False"/>
            <parameter name="Arrindex" type="Integer" array="False"/>
            <parameter name="number" type="Integer" array="False"/>
            <parameter name="Player" type="Integer" array="False"/>
        </parameters>
        <body>
            <open expression="Finale" mode="write"/>
            <comment text="appended"/>
            <for variable="i" start="0" end="number-1" direction="inc" step="1">
                <output expression="&quot;Save player rankings of score percentage to file Finale&quot;" newline="True"/>
                <write expression="&quot;Write Score,Rank,and name to file&quot;"/>
            </for>
            <close/>
            <open expression="Finale" mode="read"/>
            <for variable="i" start="0" end="number-1" direction="inc" step="1">
                <read variable="Arrvalue"/>
                <read variable="arrindex"/>
                <read variable="number"/>
                <read variable="players"/>
                <output expression="&quot;Display the contents of file Finale&quot;" newline="True"/>
            </for>
            <close/>
        </body>
    </function>
</flowgorithm>
